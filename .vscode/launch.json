            "program": "C:/Program Files/Epic Games/UE_5.7/Engine/Binaries/Win64/UnrealEditor.exe",
            "args": [
                "D:/THEGUTS/theGutsUnreal/MachineDesiring/MachineDesiring/MachineDesiring.uproject"
